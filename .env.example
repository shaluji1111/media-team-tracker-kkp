VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_or_anon_key

# Required for the current Turso-backed production data flow.
VITE_TURSO_DATABASE_URL=libsql://your-database.turso.io
VITE_TURSO_AUTH_TOKEN=your-turso-token

# Used only by scripts/seed-super-admin.mjs. Never expose this in Vite/browser code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
WORKTRACK_SUPER_ADMIN_NAME=Super Admin
WORKTRACK_SUPER_ADMIN_PASSWORD=
